# LLM provider: "github", "openai" or "anthropic"
LLM_PROVIDER=github

# GitHub Models (OpenAI-compatible, uses a GitHub PAT with the `models:read` scope)
GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-4.1-mini
GITHUB_BASE_URL=https://models.github.ai/inference

# OpenAI (alternative — leave unset when using GitHub Models)
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# App settings
APP_DATA_DIR=./data
APP_OUTPUT_DIR=./output
APP_TEMPLATES_DIR=./templates
APP_LANGUAGE=pl

# Job fetching
HTTP_TIMEOUT_SECONDS=15
HTTP_USER_AGENT=Mozilla/5.0 (compatible; CVGeneratorBot/0.1)

# Quality validator
MIN_MATCH_SCORE=70
MAX_TAILOR_ITERATIONS=2

# Google Docs (phase 2, optional)
GOOGLE_CREDENTIALS_PATH=./secrets/google_credentials.json
GOOGLE_TOKEN_PATH=./secrets/google_token.json
GOOGLE_DRIVE_TEMPLATE_ID=
